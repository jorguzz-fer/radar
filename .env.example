# ============ DATABASE ============
DATABASE_URL="postgresql://radar:radar_dev@localhost:5432/radar"
POSTGRES_PASSWORD="radar_dev"

# ============ LLMs ============
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ============ VECTOR DB ============
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=radar
PINECONE_ENVIRONMENT=...

# ============ N8N (coleta) ============
N8N_WEBHOOK_INGEST_URL=http://n8n:5678/webhook/ingest
RADARVET_API_INGEST_TOKEN=troque-por-token-secreto-forte

# ============ WHATSAPP (Evolution API) ============
EVOLUTION_API_URL=...
EVOLUTION_API_KEY=...
EVOLUTION_INSTANCE=tudomudou-bot

# ============ AUTH ============
# AUTH_SECRET: chave HMAC para assinar os JWTs de sessão do dashboard.
# Gere com: openssl rand -base64 48 (mínimo 32 caracteres).
# NUNCA reuse a mesma chave entre ambientes (dev/staging/prod).
AUTH_SECRET=

# SEED_PASSWORD: senha padrão do usuário fernando@tudomudou.com.br criado pelo seed.
# Apenas para desenvolvimento — troque no primeiro acesso em produção.
SEED_PASSWORD=radar-dev-2026!

# ============ OBSERVABILIDADE ============
BETTER_STACK_TOKEN=

# ============ APP ============
NEXT_PUBLIC_API_URL=https://api.radar.tudomudou.com.br
NODE_ENV=development
PORT=3001

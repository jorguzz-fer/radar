FROM node:20-alpine AS base
RUN corepack enable && corepack prepare pnpm@9.0.0 --activate

FROM base AS deps
WORKDIR /app
ENV NODE_ENV=development
COPY package.json pnpm-workspace.yaml ./
COPY apps/api/package.json ./apps/api/
COPY packages/database/package.json ./packages/database/
COPY packages/types/package.json ./packages/types/
COPY packages/claude-sdk/package.json ./packages/claude-sdk/
COPY packages/pinecone-sdk/package.json ./packages/pinecone-sdk/
COPY packages/vocab-packs/package.json ./packages/vocab-packs/
RUN pnpm install --no-frozen-lockfile --shamefully-hoist

FROM base AS builder
WORKDIR /app
ENV NODE_ENV=development
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN cd packages/database && ../../node_modules/.bin/prisma generate
RUN cd apps/api && ../../node_modules/.bin/nest build

FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production
COPY --from=builder /app/apps/api/dist ./dist
COPY --from=builder /app/node_modules/@prisma ./node_modules/@prisma
COPY --from=builder /app/packages/database/prisma ./prisma

EXPOSE 3001
CMD ["node", "dist/main"]
